{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WordBrain",
  "version": "0.1.1",
  "identifier": "com.lifefarmer.wordbrain",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WordBrain",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright 2026 Peilin Wu",
    "license": "MIT",
    "shortDescription": "Local-first English vocabulary builder — read, mark, grow your word network.",
    "publisher": "Peilin Wu",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "assets/ecdict.db"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5MUZFODYyMzhCQzEyMDYKUldRR0VydzRZdWdmV2NseGlPMGtCaDlGSXlhWFU1dktFOWhnaThqV0JmNHlGSUtJNjF0MG1tYnAK",
      "endpoints": [
        "https://github.com/lifefarmer/wordbrain/releases/latest/download/latest.json"
      ]
    }
  }
}
